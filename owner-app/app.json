{
  "expo": {
    "name": "PayGuard",
    "slug": "payguard-owner",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#0f0f0f",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0f0f",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.payguard.ownerapp",
      "permissions": [
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0f0f0f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "53d61483-e384-4d2f-9395-3f5a98712607"
      }
    }
  }
}
